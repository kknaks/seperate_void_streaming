# void-streaming-demo 환경 변수 예시
# 실제 값으로 교체 후 .env 로 복사 (절대 저장소에 커밋 금지)

# pyannote 모델 다운로드 (필수) — https://huggingface.co/settings/tokens
HF_TOKEN=

# ElevenLabs streaming STT (필수) — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# speaker_engine storage — 데모 default
SPEAKER_ENGINE_STORAGE_URL=memory://
